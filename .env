# Copy this file to .env and fill in your values (never commit the real .env)

# Deriv WebSocket app_id — 1089 is Deriv's public demo id, fine for market data.
DERIV_APP_ID=1089

# Telegram — see README.md for how to create a bot and find your chat id
TELEGRAM_BOT_TOKEN=8743986007:AAENkLUWg3mKEMfOGRbcEXDusgLVm9mLyHU
TELEGRAM_CHAT_ID=1242803632

# Strategy settings (all optional — defaults shown match the browser scanner)
EMA20_LEN=20
EMA50_LEN=50
EMA200_LEN=200
ATR_PERIOD=14
ATR_MULT=1.0
MIN_PULLBACK=3
ALLOW_MIXED_H1=false

# Port for the health-check HTTP endpoint (set automatically by most hosts)
PORT=3000
